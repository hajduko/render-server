# =====================================================
# Microsoft Entra ID (Azure AD)
# =====================================================

TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CLIENT_SECRET=your_microsoft_app_client_secret

# IMPORTANT: Must match the URL registered in Entra ID
APP_BASE_URL=https://render.sawin.hu

SESSION_SECRET=super_random_long_secret_string_change_me


# =====================================================
# AWS Configuration
# =====================================================

AWS_REGION=eu-central-1

S3_BUCKET=sawin-render-prod

SQS_QUEUE_URL=https://sqs.eu-central-1.amazonaws.com/123456789012/render-jobs

DDB_PROJECTS=render_projects
DDB_JOBS=render_jobs


# =====================================================
# CloudFront Signed URL Configuration
# =====================================================

CLOUDFRONT_DOMAIN=https://cdn.render.sawin.hu

# This is the CloudFront Public Key ID (NOT IAM key)
CLOUDFRONT_KEY_PAIR_ID=K2ABCDEFG123456

# Path on EC2 where you stored your private key
CLOUDFRONT_PRIVATE_KEY_PATH=/etc/render/cloudfront_private_key.pem